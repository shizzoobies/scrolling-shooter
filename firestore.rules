rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Leaderboard scores — anyone can read; anyone can add (no edit/delete)
    match /scores_v1_0/{doc} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name','score','wave','ts'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 12
                    && request.resource.data.score is number
                    && request.resource.data.wave is number;
      allow update, delete: if false;
    }
  }
}
